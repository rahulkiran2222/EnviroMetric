import time
import os
import platform
import numpy as np
import pandas as pd
import scipy.stats as stats
import matplotlib.pyplot as plt
import seaborn as sns

# --- THE RESEARCH ENGINE ---
class EcoCodeProfiler:
    def __init__(self, tdp_watts=15):
        self.tdp = tdp_watts # Default for Colab/Laptops
        self.results = []
        
    def get_hardware_access(self):
        # Checks if we are on a system that allows RAPL
        return os.path.exists("/sys/class/powercap/intel-rapl")

    def profile(self, func, name, iterations=10):
        print(f"🚀 Profiling: {name}")
        for i in range(iterations):
            start_time = time.perf_counter()
            
            # --- EXECUTION ---
            func() 
            # -----------------
            
            end_time = time.perf_counter()
            duration = end_time - start_time
            
            # ENERGY CALCULATION (Research Method: TDP Approximation)
            # Energy (Joules) = Power (Watts) * Time (Seconds)
            # In a PhD context, we assume 70% CPU load for these tasks
            estimated_power = self.tdp * 0.7 
            joules = estimated_power * duration
            
            self.results.append({
                "App_Version": name,
                "Iteration": i,
                "Duration_Sec": duration,
                "Energy_Joules": joules,
                "Timestamp": time.time()
            })
        print(f"✅ Finished {iterations} iterations.")

# --- RESEARCH USE CASE: Algorithm Comparison ---
# Use Case: Same goal, different implementation (Version A vs B)

def version_legacy():
    """Inefficient way to find primes"""
    primes = []
    for num in range(2, 5000):
        if all(num % i != 0 for i in range(2, int(num**0.5) + 1)):
            primes.append(num)
    return primes

def version_optimized():
    """Efficient Sieve of Eratosthenes"""
    n = 5000
    primes = [True] * (n + 1)
    p = 2
    while (p * p <= n):
        if (primes[p] == True):
            for i in range(p * p, n + 1, p):
                primes[i] = False
        p += 1
    return [p for p in range(2, n) if primes[p]]

# --- RUN EXPERIMENT ---
profiler = EcoCodeProfiler(tdp_watts=45) # Assume 45W TDP
profiler.profile(version_legacy, "Legacy_Code", iterations=20)
profiler.profile(version_optimized, "Optimized_Sieve", iterations=20)

# --- STATISTICAL ANALYSIS (The PhD Part) ---
df = pd.DataFrame(profiler.results)
t_stat, p_val = stats.ttest_ind(
    df[df['App_Version'] == 'Legacy_Code']['Energy_Joules'],
    df[df['App_Version'] == 'Optimized_Sieve']['Energy_Joules']
)

print(f"\n--- Statistical Report ---")
print(f"P-Value: {p_val:.10f}")
if p_val < 0.05:
    print("Conclusion: Statistically significant energy savings detected.")

# --- SAVE FOR HUGGING FACE ---
df.to_csv("energy_results.csv", index=False)
print("Data exported to energy_results.csv")
